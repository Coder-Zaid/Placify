{
  "version": 2,
  "builds": [
    {
      "src": "backend/app/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/analyze/(.*)",
      "dest": "backend/app/main.py"
    },
    {
      "src": "/auth/(.*)",
      "dest": "backend/app/main.py"
    },
    {
      "src": "/health",
      "dest": "backend/app/main.py"
    },
    {
      "src": "/(.*)\\.(js|css|png|jpg|jpeg|gif|svg|ico|json|woff|woff2|ttf|eot|mp4|webm)$",
      "dest": "frontend/$1.$2"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/index.html"
    }
  ]
}
